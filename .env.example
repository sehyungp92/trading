# =============================================================================
# Single-VPS Unified Trading Deployment — Environment Variables
# =============================================================================
# Copy to .env and fill in real values before deployment.

# --- IB Gateway (systemd-managed, shared by all families) ---
IB_HOST=127.0.0.1
IB_PORT=4002
IB_ACCOUNT_ID=DU_PLACEHOLDER

# --- PostgreSQL ---
POSTGRES_PASSWORD=changeme
POSTGRES_READER_PASSWORD=changeme
POSTGRES_WRITER_PASSWORD=changeme
DB_HOST=127.0.0.1
DB_PORT=5432
DB_NAME=trading
DB_USER=trading_admin
DB_PASSWORD=${POSTGRES_PASSWORD}

# --- Trading mode: paper | live ---
# TRADING_ENV is the canonical variable read by docker-compose.yml, coordinators,
# and strategy mains (via get_environment() fallback chain in db_config.py).
# ALGO_TRADER_ENV is a legacy fallback — only TRADING_ENV is needed.
TRADING_ENV=paper

# --- Relay ---
# Docker relay runs on port 8000 (Dockerfile.relay uvicorn).
# Non-Docker start.sh runs on port 8001.
RELAY_URL=http://127.0.0.1:8000/events
INSTRUMENTATION_RELAY_URL=${RELAY_URL}
INSTRUMENTATION_HMAC_SECRET=changeme
# JSON dict mapping bot_id to HMAC secret for webhook authentication.
# Example: {"swing_bot": "secret1", "momentum_bot": "secret2"}
RELAY_SHARED_SECRETS={}
# API key for relay GET/admin endpoints. Empty = unauthenticated dev mode.
RELAY_API_KEY=

# --- Unified config directory (baked into Docker image via COPY) ---
CONFIG_DIR=/app/config

# --- Stock Trader deploy mode (both = all 3 strategies) ---
STOCK_TRADER_DEPLOY_MODE=both

# --- Paper capital (override; default from portfolio.yaml capital.paper_initial_equity) ---
# PAPER_CAPITAL=10000
# PAPER_INITIAL_EQUITY=10000
# STOCK_TRADER_PAPER_CAPITAL=10000

# --- FRED API (free, for regime backtest macro data) ---
# Register at https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=

# --- Python ---
PYTHONUNBUFFERED=1
