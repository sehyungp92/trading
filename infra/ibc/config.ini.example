# IBC Configuration for Paper Trading
# Copy to /opt/ibc/config/config.ini and fill in credentials

# IBKR Credentials (paper trading)
IbLoginId=YOUR_IBKR_USERNAME
IbPassword=YOUR_IBKR_PASSWORD

# Paper trading mode
TradingMode=paper

# Auto-accept non-brokerage account warning
AcceptNonBrokerageAccountWarning=yes

# Existing session handling
ExistingSessionDetectedAction=primary

# Auto-restart settings (IBKR resets connections daily ~midnight ET)
AutoRestartTime=00:00

# Accept incoming connections (needed for strategies to connect)
AcceptIncomingConnectionAction=accept

# Allow API connections (both must be 'no' for order placement)
ReadOnlyLogin=no
ReadOnlyApi=no

# Dismiss various popups automatically
DismissPasswordExpiryWarning=yes
DismissNSEComplianceNotice=yes

# Gateway port for paper trading
OverrideTwsApiPort=4002

# Gateway mode (not TWS)
FIX=no
