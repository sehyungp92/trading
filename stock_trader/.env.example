# Runtime mode: dev | backtest | paper | live
ALGO_TRADER_ENV=paper

# Shared PostgreSQL from the swing_trader VPS stack
# Containers use network_mode: host, so 127.0.0.1 reaches PostgreSQL directly
DB_HOST=127.0.0.1
DB_PORT=5432
DB_NAME=trading
DB_USER=trading_writer
DB_PASSWORD=

# Shared IB Gateway running on the VPS host
# Containers use network_mode: host, so 127.0.0.1 reaches the gateway directly
IB_HOST=127.0.0.1
IB_PORT=4002
IB_ACCOUNT_ID=

# Unique client IDs for this repo's three strategy containers
IB_CLIENT_ID_IARIC=33
IB_CLIENT_ID_US_ORB=32
IB_CLIENT_ID_ALCB=34

# Virtual starting equity for paper/dev mode (ignored in live)
# Tracks own P&L via baseline: equity = PAPER_CAPITAL + (actual_net_liq - baseline)
STOCK_TRADER_PAPER_CAPITAL=10000

# Deployment mode and capital split for the three live strategies
STOCK_TRADER_DEPLOY_MODE=both
STOCK_TRADER_CAPITAL_ALLOCATION_IARIC_PCT=33.333333
STOCK_TRADER_CAPITAL_ALLOCATION_US_ORB_PCT=33.333333
STOCK_TRADER_CAPITAL_ALLOCATION_ALCB_PCT=33.333334

# Standardized instrumentation relay endpoint on the same VPS host
# Containers use network_mode: host, so 127.0.0.1 reaches the relay directly
INSTRUMENTATION_RELAY_URL=http://127.0.0.1:8001/events
INSTRUMENTATION_HMAC_SECRET=

# Optional experiment metadata
EXPERIMENT_ID=
EXPERIMENT_VARIANT=
