# Environment: dev | backtest | paper | live
SWING_TRADER_ENV=paper

# IBKR connection
IB_ACCOUNT_ID=DU1234567
IB_HOST=host.docker.internal
IB_PORT=4002

# Database (PostgreSQL)
POSTGRES_PASSWORD=changeme
POSTGRES_READER_PASSWORD=changeme
POSTGRES_WRITER_PASSWORD=changeme
DB_HOST=postgres
DB_PORT=5432
DB_NAME=trading
DB_USER=trading_writer
DB_PASSWORD=changeme

# Paper capital: virtual starting equity (requires SWING_TRADER_ENV=paper or dev)
# Ignored on live to prevent accidental mis-sizing.
# When set, position sizing uses this as portfolio starting capital instead of
# the full account balance. Equity grows/shrinks dynamically with realized P&L.
# Delete config/paper_capital_state.json to reset the baseline.
# PAPER_CAPITAL=10000

# Strategy symbol sets (optional overrides)
# ATRSS_SYMBOL_SET=etf
# AKCHELIX_SYMBOL_SET=etf

# Instrumentation — HMAC secret for sidecar → relay signing
# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
# Must match the bot's entry in /opt/trading-relay/secrets.json
INSTRUMENTATION_HMAC_SECRET=
