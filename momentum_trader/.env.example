# Environment: dev | backtest | paper | live
ALGO_TRADER_ENV=paper

# PostgreSQL (same VPS — localhost)
DB_HOST=127.0.0.1
DB_PORT=5432
DB_NAME=trading
DB_USER=trading_writer
DB_PASSWORD=

# IB Gateway (same VPS — localhost)
IB_HOST=127.0.0.1
IB_PORT=4002
IB_ACCOUNT_ID=

# IB client IDs (must be unique per running strategy container)
# ETF strategies on VPS 1: 1-10, Momentum strategies: 11-20
IB_CLIENT_ID_HELIX=11
IB_CLIENT_ID_NQDTC=12
IB_CLIENT_ID_VDUBUS=13

# Paper trading simulated equity (only used when ALGO_TRADER_ENV=paper)
PAPER_INITIAL_EQUITY=10000

# Trading instrument (NQ for full-size, MNQ for micro)
TRADING_SYMBOL=MNQ

# Instrumentation (sidecar event forwarding to relay on VPS 1)
# Generate secret: python3 -c "import secrets; print(secrets.token_hex(32))"
# Must match the entry in VPS 1's /opt/trading-relay/secrets.json
INSTRUMENTATION_HMAC_SECRET=
INSTRUMENTATION_RELAY_URL=http://127.0.0.1:8001/events

# Experiment tracking (A-B testing / feature flags)
EXPERIMENT_ID=
EXPERIMENT_VARIANT=
