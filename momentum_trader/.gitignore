*.py[cod]
*$py.class
*.so
*.egg
*.egg-info/
dist/
build/
.pytest_cache/
.mypy_cache/
.coverage
htmlcov/

# ── Virtual environment ──────────────────────────────
venv/
.venv/
env/

# ── Environment / secrets ────────────────────────────
.env
