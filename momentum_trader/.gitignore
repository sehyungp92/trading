.vscode/
.idea/
*.swp
*.swo
*~

# ── Test artifacts (mock leak prevention) ────────────
MagicMock/
mock.*/

# ── OS ───────────────────────────────────────────────
.DS_Store
Thumbs.db
ehthumbs.db

# ── Claude Code local settings ───────────────────────
